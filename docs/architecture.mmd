    classDef data fill:#111827,stroke:#f472b6,color:#e5e7eb;
    classDef assets fill:#111827,stroke:#a78bfa,color:#e5e7eb;

    class UI,AX client;
    class ROUTER,MW api;
    class CTRL app;
